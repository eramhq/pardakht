{
    "name": "eramhq/pardakht",
    "description": "A PSR-compliant, framework-agnostic PHP library for Iranian payment gateways",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "payment",
        "gateway",
        "iran",
        "pardakht",
        "mellat",
        "saman",
        "parsian",
        "sadad",
        "pasargad",
        "zarinpal",
        "idpay",
        "zibal"
    ],
    "authors": [
        {
            "name": "Eram.dev",
            "homepage": "https://eram.dev"
        }
    ],
    "homepage": "https://github.com/eramhq/pardakht",
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-soap": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/log": "^2.0 || ^3.0",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.40",
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/psr7": "^2.0",
        "php-http/mock-client": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "EramDev\\Pardakht\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EramDev\\Pardakht\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
